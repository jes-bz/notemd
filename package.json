{
  "name": "notemd",
  "displayName": "Notemd",
  "icon": "logo.png",
  "description": "A markdown note-taking environment with WYSIWYG editing.",
  "version": "0.0.4",
  "publisher": "jesbz",
  "repository": {
    "type": "git",
    "url": "https://github.com/jes-bz/notemd.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "markdown",
    "notes",
    "editor",
    "wysiwyg"
  ],
  "activationEvents": [
    "onCommand:notemd.openEditor",
    "onCommand:notemd.openDailyNote",
    "onCommand:notemd.reindexOcr",
    "onCommand:notemd.reindexOcrAll",
    "onCommand:notemd.setOcrApiKey",
    "onWebviewPanel:notemd",
    "onLanguage:markdown",
    "onCustomEditor:notemd.customEditor"
  ],
  "main": "out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "notemd.openEditor",
        "title": "Open with Notemd",
        "category": "notemd"
      },
      {
        "command": "notemd.revealInSource",
        "title": "Reveal in Source",
        "category": "notemd"
      },
      {
        "command": "notemd.openDailyNote",
        "title": "Open Today's Daily Note",
        "category": "notemd"
      },
      {
        "command": "notemd.reindexOcr",
        "title": "Reindex OCR (current file)",
        "category": "notemd"
      },
      {
        "command": "notemd.reindexOcrAll",
        "title": "Reindex OCR (all markdown files)",
        "category": "notemd"
      },
      {
        "command": "notemd.setOcrApiKey",
        "title": "Set OCR API Key",
        "category": "notemd"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceLangId == markdown",
          "command": "notemd.openEditor",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "when": "resourceLangId == markdown",
          "command": "notemd.openEditor",
          "group": "1_open"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "notemd.customEditor",
        "displayName": "Notemd",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          }
        ],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "notemd",
      "properties": {
        "notemd.imageSaveFolder": {
          "type": "string",
          "default": "assets",
          "description": "Save images to which folder when upload in markdown, default relative to the markdown file, you can set to project root via `${projectRoot}/assets`."
        },
        "notemd.useVscodeThemeColor": {
          "type": "boolean",
          "default": true,
          "description": "Use vscode theme's background color as the editor's background color."
        },
        "notemd.customCss": {
          "type": "string",
          "default": ""
        },
        "notemd.dailyNoteFolder": {
          "type": "string",
          "default": "",
          "description": "Folder for daily notes, relative to workspace root. Leave empty to use workspace root."
        },
        "notemd.dailyNoteFormat": {
          "type": "string",
          "default": "yyyy-MM-dd",
          "description": "Date format for daily note filenames. Uses date-fns format syntax (e.g., yyyy-MM-dd, yyyy/MMMM/yyyy-MM-dd)."
        },
        "notemd.ocr.endpoint": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "OpenAI-compatible API base URL for OCR. Example: https://api.openai.com/v1"
        },
        "notemd.ocr.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "Vision-capable model name used for OCR."
        },
        "notemd.ocr.prompt": {
          "type": "string",
          "default": "Extract all text from this image exactly as it appears. Return only the raw text with no commentary, no markdown, no quoting. If the image contains no text, return an empty string.",
          "description": "Prompt sent with each image to the OCR model."
        }
      }
    },
    "keybindings": [
      {
        "key": "ctrl+shift+alt+m",
        "command": "notemd.openEditor",
        "mac": "cmd+shift+alt+m",
        "when": "editorTextFocus && editorLangId == markdown"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p ./ && esbuild ./src/media/main.ts --bundle --minify --sourcemap --outfile=./media/dist/main.js && cp node_modules/vditor/dist/js/lute/lute.min.js media/dist/",
    "compile": "tsc -p ./",
    "package": "npm run build && npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "jquery": "^3.6.0",
    "jquery-confirm": "^3.3.4",
    "typescript": "^5.7.0",
    "vditor": "^3.8.4"
  },
  "dependencies": {
    "diff": "^8.0.4"
  }
}